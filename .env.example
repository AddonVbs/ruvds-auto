# Telegram
TELEGRAM_TOKEN=123456:AA...
OWNER_TG_ID=123456789

# RuVDS API v2 token from https://ruvds.com/my/settings/api
RUVDS_TOKEN=

# --- VDS defaults (со скриншота: 1 ядро / 1 ГБ / 20 ГБ HDD RAID / 6 IP / Ubuntu 24.04) ---
# DEFAULT_DATACENTER используется только если ALLOWED_DATACENTERS пуст.
# Конкретные ID получи через /info в боте после первого запуска.
DEFAULT_DATACENTER=1
# Разрешённые ДЦ (id через запятую): Rucloud, Ostankino, Linxdatacenter, M9
ALLOWED_DATACENTERS=
DEFAULT_TARIFF_ID=
DEFAULT_OS_ID=
DEFAULT_PAYMENT_PERIOD=2
DEFAULT_CPU=1
DEFAULT_RAM=1
DEFAULT_DRIVE=20
# HDD RAID = drive_tariff_id (см. /info → drive_tariffs у ДЦ)
DEFAULT_DRIVE_TARIFF_ID=1
DEFAULT_IP_COUNT=6
COMPUTER_NAME=auto-vds

# --- Postgres ---
Password=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_NAME=postgres
