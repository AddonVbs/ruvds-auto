# Telegram
TELEGRAM_TOKEN=123456:AA...
OWNER_TG_ID=123456789

# RuVDS API v2 token from https://ruvds.com/my/settings/api
RUVDS_TOKEN=

# --- VDS defaults (со скриншота: 1 ядро / 1 ГБ / 20 ГБ HDD / 6 IP / Ubuntu 24.04) ---
# DEFAULT_DATACENTER используется только если ALLOWED_DATACENTERS пуст.
DEFAULT_DATACENTER=1
# Разрешённые ДЦ (id через запятую):
#   1  = Бункер/Rucloud: Россия, Королёв
#   5  = M9: Россия, Москва
#   8  = Linxdatacenter: Россия, Санкт-Петербург
#   32 = Ostankino: Россия, Москва
ALLOWED_DATACENTERS=1,5,8,32
# 14 = Regular (базовый, есть во всех 4 ДЦ)
DEFAULT_TARIFF_ID=14
# 255 = Ubuntu 24.04 LTS
DEFAULT_OS_ID=255
# 2 = 1 месяц (при удалении остаток возвращается на баланс)
DEFAULT_PAYMENT_PERIOD=2
DEFAULT_CPU=1
DEFAULT_RAM=1
DEFAULT_DRIVE=20
# 1 = HDD (в UI отображается как "HDD RAID")
DEFAULT_DRIVE_TARIFF_ID=1
DEFAULT_IP_COUNT=6
COMPUTER_NAME=auto-vds

# --- Postgres ---
Password=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_NAME=postgres
